# Dependencies
node_modules/
integrations/*/package-lock.json
# The published TS client needs a committed lockfile for CI reproducibility
# (npm ci requires it). Other integrations stay ignored.
!integrations/typescript-client/package-lock.json

# Build output
dist/

# Data directories (runtime)
data/

# Environment (secrets)
.env
.env.local
.env.*.local

# Policy (copy from policy.example.yaml)
policy.yaml

# Local docker-compose overrides (dev DB URLs, host-specific networking)
docker-compose.override.yaml
docker-compose.override.yml

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Test coverage
coverage/

# Logs and recordings
*.log
*.cast
*.mp4
*.gif
