{
  "name": "@runestone-labs/gatekeeper-mcp",
  "version": "0.1.1",
  "description": "MCP server that runs agent tool calls (shell, files, HTTP, …) through Runestone Gatekeeper — policy enforcement, human approval, and audit for any MCP client",
  "type": "module",
  "bin": {
    "gatekeeper-mcp": "dist/index.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "server.json",
    "README.md",
    "LICENSE"
  ],
  "mcpName": "io.github.Runestone-Labs/gatekeeper",
  "scripts": {
    "build": "tsc",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.13.0",
    "@runestone-labs/gatekeeper-client": "^0.3.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "typescript": "^5.7.3",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "gatekeeper",
    "runestone",
    "ai",
    "agent",
    "agentic",
    "llm",
    "guardrails",
    "ai-safety",
    "tool-use",
    "security",
    "policy",
    "approval",
    "audit"
  ],
  "author": "Runestone Labs",
  "license": "Apache-2.0",
  "homepage": "https://github.com/Runestone-Labs/gatekeeper/tree/main/integrations/mcp-server",
  "bugs": {
    "url": "https://github.com/Runestone-Labs/gatekeeper/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Runestone-Labs/gatekeeper.git",
    "directory": "integrations/mcp-server"
  }
}
